    "antd": "^5.26.6",
    "axios": "^1.11.0",
    "classnames": "^2.5.1",
    "crypto-js": "^4.2.0",
    "nanoid": "^5.1.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",

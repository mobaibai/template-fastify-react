{
  "name": "@repo/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && esbuild src/server.ts --bundle --platform=node --format=cjs --out-extension:.js=.cjs --outfile=dist/bundle.cjs",
    "start": "NODE_ENV=production node dist/bundle.cjs",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json,md}\""
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@repo/schema": "workspace:*",
    "@repo/types": "workspace:*",
    "fastify": "^5.3.2",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "dotenv-cli": "catalog:",
    "esbuild": "catalog:",
    "eslint": "catalog:",
    "tsx": "^4.19.4",
    "typescript": "catalog:"
  }
}
